# Shopify Headless Storefront API
# Copy this file to .env.local and fill in your values (do not commit .env.local).
#
# Optional: Canonical URL for SEO and sitemap (default: https://party-barn.vercel.app or Vercel deployment URL)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
#
# The "store password" (Coming soon / Enter password) is NOT used here.
# The API only uses the Storefront access token from your Headless channel.

# Store domain (no https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=party-barn-mercantile.myshopify.com

# Storefront API access token from: Shopify Admin → Settings → Apps and sales channels
# → Headless → your channel → "Storefront API access token" (or "Public access token").
# Do NOT use the store password or an Admin API token.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: same token without NEXT_PUBLIC_ (server-only). Use one or the other.
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Nicole party-planning chatbot (xAI Grok). Get key: https://console.x.ai/
XAI_API_KEY=

# Neon Postgres (for saving chat conversations). Get URL: https://neon.tech → Create project → Connection string
# Use DATABASE_URL locally; Vercel often uses STORAGE_DATABASE_URL — the app supports both.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
# STORAGE_DATABASE_URL=postgresql://...

# SendGrid (transcript emails from Nicole). Create key: SendGrid → Settings → API Keys
SENDGRID_API_KEY=
# Verified sender in SendGrid (Single Sender or Domain)
SENDER_EMAIL=
SENDER_NAME=Nicole at Party Barn
# Optional: BCC for transcript emails (default: gmiller@jgmcreative.com). Comma-separated to add Nicole's store email later.
# TRANSCRIPT_BCC_EMAIL=gmiller@jgmcreative.com

# Optional: If set, /api/cron/send-transcripts must be called with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
