# Shopify Headless Storefront API
# Copy this file to .env.local and fill in your values (do not commit .env.local).
#
# The "store password" (Coming soon / Enter password) is NOT used here.
# The API only uses the Storefront access token from your Headless channel.

# Store domain (no https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=party-barn-mercantile.myshopify.com

# Storefront API access token from: Shopify Admin → Settings → Apps and sales channels
# → Headless → your channel → "Storefront API access token" (or "Public access token").
# Do NOT use the store password or an Admin API token.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: same token without NEXT_PUBLIC_ (server-only). Use one or the other.
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
